</head>
<body>

<!-- Password Screen -->
<div id="loginOverlay">
    <div class="login-card">
        <h2>Sher Pharmacy</h2>
        <p>Enter Password to access Register</p>
        <input type="password" id="passInput" placeholder="Password" onkeydown="if(event.key==='Enter') checkPass()">
        <button onclick="checkPass()" style="width: 100%; padding: 12px; font-weight: bold;">Unlock</button>
        <p id="errorMsg" style="color: red; margin-top: 10px; display: none;">❌ Incorrect Password!</p>
    </div>
</div>

<div class="container" id="mainContainer">
    <div class="header">Sher Pharmacy</div>

    <div class="top">
        <button onclick="changeDay(-1)">⏮️ Previous Day</button>
        <input type="date" id="date" onchange="load()">
        <button onclick="changeDay(1)">Next Day ▶️</button>
    </div>

    <div class="topLine">
        <div><strong>Day:</strong> <span id="dayName"></span></div>
        <div><strong>Electricity:</strong> <input type="number" id="electricBill" value="0" oninput="saveExtra()"></div>
        <div><strong>Telephone:</strong> <input type="number" id="phoneBill" value="0" oninput="saveExtra()"></div>
        <a href="https://talhaahmad2087-dot.github.io/my-website/talha.html">Odar/ loan</a>
    </div>

    <input type="text" id="searchBox" placeholder="🔍 Search Company Name..." oninput="filterCompany()">

    <div class="tableWrap">
        <table id="dataTable">
            <thead>
                <tr>
                    <th style="width: 20%;">Company</th>
                    <th style="width: 10%;">Bill</th>
                    <th style="width: 10%;">Baqaya</th>
                    <th style="width: 25%;">Order Details</th>
                    <th style="width: 10%;">Order Pay</th>
                    <th style="width: 10%;">Sale</th>
                    <th style="width: 5%;">Action</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                <!-- Rows added by JS -->
            </tbody>
        </table>
    </div>

    <div class="controls">
        <button onclick="addRow()">➕ Add Row</button>
        <button onclick="exportData()">📤 Export Data</button>
        <input type="file" id="importFile" style="display:none;" onchange="importData(event)">
        <button onclick="document.getElementById('importFile').click()">📥 Import Data</button>
        <button onclick="window.print()">🖨️ Print Report</button>
    </div>

    <div class="summary-grid">
        <div class="card">
            <div class="card-title">Today Summary</div>
            <div class="row-data"><span>Total Bill:</span> <span>Rs <span id="billT">0</span></span></div>
            <div class="row-data"><span>Order Paid:</span> <span>Rs <span id="orderT">0</span></span></div>
            <div class="row-data"><span>Daily Sale:</span> <span>Rs <span id="saleT">0</span></span></div>
            <div class="row-data"><span>Baqaya:</span> <span>Rs <span id="baqayaT">0</span></span></div>
            <div class="row-data"><span>Electric:</span> <span>Rs <span id="eTotal">0</span></span></div>
            <div class="row-data"><span>Phone:</span> <span>Rs <span id="pTotal">0</span></span></div>
        </div>

        <div class="card">
            <div class="card-title">Monthly Summary</div>
            <div class="row-data"><span>Bill:</span> <span>Rs <span id="mBill">0</span></span></div>
            <div class="row-data"><span>Order:</span> <span>Rs <span id="mOrder">0</span></span></div>
            <div class="row-data"><span>Sale:</span> <span>Rs <span id="mSale">0</span></span></div>
            <div class="row-data"><span>Baqaya:</span> <span>Rs <span id="mBaqaya">0</span></span></div>
            <div class="row-data"><span>Electric:</span> <span>Rs <span id="mElectric">0</span></span></div>
            <div class="row-data"><span>Phone:</span> <span>Rs <span id="mPhone">0</span></span></div>
        </div>

        <div class="card">
            <div class="card-title">Yearly Summary</div>
            <div class="row-data"><span>Bill:</span> <span>Rs <span id="yBill">0</span></span></div>
            <div class="row-data"><span>Order:</span> <span>Rs <span id="yOrder">0</span></span></div>
            <div class="row-data"><span>Sale:</span> <span>Rs <span id="ySale">0</span></span></div>
            <div class="row-data"><span>Baqaya:</span> <span>Rs <span id="yBaqaya">0</span></span></div>
        </div>

        <div class="card" id="companyCard">
            <div class="card-title">Search Result</div>
            <div class="row-data"><span>Bill:</span> <span>Rs <span id="cBill">0</span></span></div>
            <div class="row-data"><span>Order:</span> <span>Rs <span id="cOrder">0</span></span></div>
            <div class="row-data"><span>Sale:</span> <span>Rs <span id="cSale">0</span></span></div>
            <div class="row-data"><span>Baqaya:</span> <span>Rs <span id="cBaqaya">0</span></span></div>
        </div>
    </div>
</div>

<script>
    const dateInput = document.getElementById("date");
    const dayName = document.getElementById("dayName");
    const tableBody = document.getElementById("tableBody");
    const days = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"];

    // Password Logic
    function checkPass() {
        const input = document.getElementById("passInput").value;
        const correctPass = "0809";
        
        if (input === correctPass) {
            document.getElementById("loginOverlay").style.display = "none";
            document.getElementById("mainContainer").style.display = "block";
            initApp();
        } else {
            document.getElementById("errorMsg").style.display = "block";
            document.getElementById("passInput").value = "";
        }
    }

    // Initialize App after login
    function initApp() {
        dateInput.value = new Date().toISOString().split("T")[0];
        load();
    }

    function saveExtra() {
        const e = +document.getElementById("electricBill").value || 0;
        const p = +document.getElementById("phoneBill").value || 0;
        document.getElementById("eTotal").innerText = e;
        document.getElementById("pTotal").innerText = p;
        localStorage.setItem(dateInput.value + "_extra", JSON.stringify({e, p}));
        calcMY();
    }

    function loadExtra() {
        let ex = JSON.parse(localStorage.getItem(dateInput.value + "_extra") || '{"e":0,"p":0}');
        document.getElementById("electricBill").value = ex.e;
        document.getElementById("phoneBill").value = ex.p;
        document.getElementById("eTotal").innerText = ex.e;
        document.getElementById("pTotal").innerText = ex.p;
    }

    function addRow(d = {}) {
        const tr = document.createElement("tr");
        tr.innerHTML = `
            <td><input type="text" value="${d.c || ""}" placeholder="Company Name"></td>
            <td><input type="number" value="${d.b || ""}" placeholder="0"></td>
            <td><input type="number" value="${d.q || ""}" placeholder="0"></td>
            <td><textarea placeholder="Items details...">${d.o || ""}</textarea></td>
            <td><input type="number" value="${d.op || ""}" placeholder="0"></td>
            <td><input type="number" value="${d.s || ""}" placeholder="0"></td>
            <td><button class="delete-btn" onclick="deleteRow(this)">❌</button></td>
        `;
        tableBody.appendChild(tr);
        tr.querySelectorAll("input, textarea").forEach(input => {
            input.oninput = save;
        });
    }

    function deleteRow(btn) {
        if(confirm("Are you sure you want to delete this row?")) {
            btn.closest("tr").remove();
            save();
        }
    }

    function save() {
        let rowsData = [];
        let tBill = 0, tBaqaya = 0, tOrder = 0, tSale = 0;

        document.querySelectorAll("#tableBody tr").forEach(tr => {
            let inputs = tr.querySelectorAll("input, textarea");
            if (inputs.length < 6) return;
            let data = {
                c: inputs[0].value,
                b: +inputs[1].value || 0,
                q: +inputs[2].value || 0,
                o: inputs[3].value,
                op: +inputs[4].value || 0,
                s: +inputs[5].value || 0
            };
            
            tBill += data.b;
            tBaqaya += data.q;
            tOrder += data.op;
            tSale += data.s;
            
            rowsData.push(data);
        });

        document.getElementById("billT").innerText = tBill;
        document.getElementById("baqayaT").innerText = tBaqaya;
        document.getElementById("orderT").innerText = tOrder;
        document.getElementById("saleT").innerText = tSale;

        localStorage.setItem(dateInput.value, JSON.stringify(rowsData));
        calcMY();
        filterCompany();
    }

    function load() {
        tableBody.innerHTML = "";
        let savedData = JSON.parse(localStorage.getItem(dateInput.value) || "[]");
        
        if (savedData.length === 0) {
            for (let i = 0; i < 5; i++) addRow();
        } else {
            savedData.forEach(item => addRow(item));
        }

        dayName.innerText = days[new Date(dateInput.value).getDay()];
        loadExtra();
        save();
    }

    function changeDay(n) {
        let d = new Date(dateInput.value);
        d.setDate(d.getDate() + n);
        dateInput.value = d.toISOString().split("T")[0];
        load();
    }

    function calcMY() {
        let mB = 0, mO = 0, mQ = 0, mS = 0, mE = 0, mP = 0;
        let yB = 0, yO = 0, yQ = 0, yS = 0;
        
        let currentMonth = dateInput.value.slice(0, 7);
        let currentYear = dateInput.value.slice(0, 4);

        Object.keys(localStorage).forEach(key => {
            if (key.endsWith("_extra")) {
                let dateKey = key.replace("_extra", "");
                let ex = JSON.parse(localStorage.getItem(key));
                if (dateKey.startsWith(currentMonth)) {
                    mE += ex.e; mP += ex.p;
                }
                return;
            }

            if (/^\d{4}-\d{2}-\d{2}$/.test(key)) {
                let rows = JSON.parse(localStorage.getItem(key) || "[]");
                rows.forEach(r => {
                    if (key.startsWith(currentMonth)) {
                        mB += (r.b || 0); mO += (r.op || 0); mQ += (r.q || 0); mS += (r.s || 0);
                    }
                    if (key.startsWith(currentYear)) {
                        yB += (r.b || 0); yO += (r.op || 0); yQ += (r.q || 0); yS += (r.s || 0);
                    }
                });
            }
        });

        document.getElementById("mBill").innerText = mB;
        document.getElementById("mOrder").innerText = mO;
        document.getElementById("mBaqaya").innerText = mQ;
        document.getElementById("mSale").innerText = mS;
        document.getElementById("mElectric").innerText = mE;
        document.getElementById("mPhone").innerText = mP;

        document.getElementById("yBill").innerText = yB;
        document.getElementById("yOrder").innerText = yO;
        document.getElementById("yBaqaya").innerText = yQ;
        document.getElementById("ySale").innerText = yS;
    }

    function filterCompany() {
        let filter = document.getElementById("searchBox").value.toLowerCase();
        let cB = 0, cO = 0, cS = 0, cQ = 0;

        document.querySelectorAll("#tableBody tr").forEach(tr => {
            let inputs = tr.querySelectorAll("input");
            if(inputs.length === 0) return;
            let companyName = inputs[0].value.toLowerCase();
            
            if (companyName.includes(filter)) {
                tr.style.display = "";
                if (filter !== "") {
                    cB += +inputs[1].value || 0;
                    cQ += +inputs[2].value || 0;
                    cO += +inputs[3].value || 0;
                    cS += +inputs[4].value || 0;
                }
            } else {
                tr.style.display = "none";
            }
        });

        document.getElementById("cBill").innerText = cB;
        document.getElementById("cOrder").innerText = cO;
        document.getElementById("cSale").innerText = cS;
        document.getElementById("cBaqaya").innerText = cQ;
        
        document.getElementById("companyCard").style.borderColor = filter === "" ? "#1f3c88" : "#28a745";
    }

    function exportData() {
        const data = {};
        for (let i = 0; i < localStorage.length; i++) {
            const key = localStorage.key(i);
            data[key] = localStorage.getItem(key);
        }
        const blob = new Blob([JSON.stringify(data)], {type: "application/json"});
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `SherPharmacy_Backup_${new Date().toISOString().split('T')[0]}.json`;
        a.click();
    }

    function importData(e) {
        const file = e.target.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = function(ev) {
            try {
                const imported = JSON.parse(ev.target.result);
                Object.keys(imported).forEach(k => localStorage.setItem(k, imported[k]));
                alert("Data imported successfully!");
                load();
            } catch (err) {
                alert("Error importing file. Make sure it's a valid backup.");
            }
        };
        reader.readAsText(file);
    }
</script>
</body>
</html>
