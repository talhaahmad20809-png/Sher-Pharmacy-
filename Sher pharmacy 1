<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sher Pharmacy Register</title>
    <style>
        // Import the functions you need from the SDKs you need
